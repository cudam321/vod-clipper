# Copy this file to .env and fill in your values.
# Do NOT commit your real .env — it is gitignored.

# ============================================================
#  OpenAI (Whisper transcription)
# ============================================================
# Whisper runs against OpenAI directly (OpenRouter doesn't proxy audio models).
OPENAI_API_KEY=your-openai-api-key

# ============================================================
#  OpenRouter (highlight analysis)
# ============================================================
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional — override the OpenRouter base URL (defaults to the value below)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Analysis model (change to try different models)
# Options: openai/gpt-4o-mini, openai/gpt-4o, anthropic/claude-3.5-sonnet,
#          google/gemini-2.0-flash-001, deepseek/deepseek-chat
ANALYSIS_MODEL=openai/gpt-4o-mini

# ============================================================
#  Dropbox
# ============================================================
# Run `python setup_dropbox.py` to obtain the app key/secret + refresh token.
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_REFRESH_TOKEN=your-dropbox-refresh-token

# Optional short-lived fallback token (expires ~4h). Prefer the refresh token above.
# DROPBOX_ACCESS_TOKEN=

# Dropbox folder the watcher monitors for new VODs (default: /VODs)
# DROPBOX_VODS_FOLDER=/VODs

# ============================================================
#  Notion
# ============================================================
# Run `python notion_sync.py --setup` for step-by-step instructions.
NOTION_API_KEY=your-notion-integration-secret
# Database ID of your "Stream Content Log" database (from its URL).
NOTION_MASTER_DB_ID=your-notion-database-id

# ============================================================
#  Content configuration (de-branding — customize for your creator)
# ============================================================
# Channel/creator label used in filenames and Notion rows.
CHANNEL=channel

# Free-text description of the creator and what to prioritize when picking clips.
# Tailor this to your content for better highlight selection.
# CREATOR_CONTEXT=A content creator who hosts live streams and long-form videos. Prioritize engaging, informative, entertaining, or shareable moments.
